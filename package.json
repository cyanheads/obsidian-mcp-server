{
  "name": "obsidian-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for interacting with Obsidian vaults via the Model Context Protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "obsidian-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "rebuild": "tsx scripts/clean.ts && tsx scripts/build.ts",
    "clean": "tsx scripts/clean.ts",
    "devcheck": "tsx scripts/devcheck.ts",
    "tree": "tsx scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "tsx scripts/lint-mcp.ts",
    "changelog:build": "tsx scripts/build-changelog.ts",
    "changelog:check": "tsx scripts/build-changelog.ts --check",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio tsx --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http tsx --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": ["mcp", "mcp-server", "model-context-protocol"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/obsidian-mcp-server.git"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.7.5",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.6.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
